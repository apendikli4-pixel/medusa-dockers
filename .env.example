# ═══════════════════════════════════════════════════════════════
# PROJECT AYNA GENESIS — Environment Variables
# Kopyala: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_DB=medusa-store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Medusa Core ──
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/medusa-genesis
REDIS_URL=redis://redis:6379
JWT_SECRET=supersecret-change-in-production
COOKIE_SECRET=supersecret-change-in-production
STORE_CORS=http://localhost:8000,http://localhost:7001
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:9000,http://localhost:7001

# ── Meilisearch ──
MEILISEARCH_MASTER_KEY=masterKey123

# ── AI (Gemini + Ollama) ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-2.0-flash
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL_NAME=llama3

# ── Publishable API Key (Medusa Admin'den alınır) ──
PUBLISHABLE_API_KEY=

# ── n8n Bridge (Hallucination Killer) ──
# true = Tüm chat mesajları n8n üzerinden grounding + validation ile işlenir
# false = Eski direkt-LLM modu (varsayılan)
N8N_BRIDGE_ENABLED=false
N8N_WEBHOOK_URL=http://n8n:5678
N8N_CHAT_WEBHOOK_PATH=/webhook/ayna-grounded-chat
N8N_TIMEOUT_MS=30000

# ── n8n Servis ──
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL_EXTERNAL=http://localhost:5678/
TZ=Europe/Istanbul

# ── Payment Providers ──
USE_MOCK_PROVIDERS=true
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=

# ── Cloudinary ──
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Brevo (Email) ──
# BREVO_API_KEY=
