# ═══════════════════════════════════════════════════════════════
# PROJECT AYNA GENESIS — Environment Variables
# Kopyala: cp .env.example .env  (sonra TÜM placeholder değerleri DOLDUR)
# Production'da boş kalan kritik değişkenler servisi başlatmaz.
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_DB=medusa-genesis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Medusa Core (zorunlu) ──
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/medusa-genesis
REDIS_URL=redis://redis:6379
# Üretimde 64+ karakter rastgele string kullan (örn: openssl rand -hex 64)
JWT_SECRET=change-me-supersecret-jwt
COOKIE_SECRET=change-me-supersecret-cookie
STORE_CORS=http://localhost:8000,http://localhost:7001
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:9000,http://localhost:7001

# ── Meilisearch ──
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-meili-master-key

# ── AI (Ollama — açık kaynak, tek motor; Gemini kaldırıldı) ──
OLLAMA_API_URL=http://host.docker.internal:11434
OLLAMA_MODEL_NAME=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=290000

# ── Publishable API Key (Medusa Admin'den alınır, storefront için) ──
PUBLISHABLE_API_KEY=

# ── Default Tenant (single-tenant deployment için) ──
# Admin SPA ve API çağrıları x-tenant-id header'ı gönderemediğinde bu ID
# kullanılır. Multi-tenant moda geçtiğinde boş bırakın — header zorunlu olur.
# Tenant bootstrap: docker exec medusa_postgres_v2 psql -U $POSTGRES_USER \
#   -d <db> -c "INSERT INTO tenant (id,name,slug,sector) VALUES \
#   ('tnt_default','My Store','default','retail');"
DEFAULT_TENANT_ID=

# ── Storefront (Next.js — NEXT_PUBLIC_* tarayıcıya bundle'lanır!) ──
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_SEARCH_ENDPOINT=http://localhost:7700

TZ=Europe/Istanbul

# ── Payment Providers ──
# false yap → gerçek PayTR/İyzico anahtarlarını kullan
USE_MOCK_PROVIDERS=true
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Shipping (Yurtiçi Kargo) ──
# YURTICI_USERNAME=
# YURTICI_PASSWORD=

# ── Cloudinary (medya hosting) ──
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Brevo (transactional email) ──
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=noreply@example.com
# BREVO_FROM_NAME="Aqua Havuz"

# ── Self-Servis Kayıt (SaaS onboarding) ──
# BREVO_WELCOME_TEMPLATE_ID=            # yeni mağaza hoş geldin e-postası şablonu (yoksa e-posta atlanır)

# ── Terk Edilmiş Sepet Kurtarma (opsiyonel; tenant-özel şablon settings.storefront.email.templates.abandonedCart önceliklidir) ──
# BREVO_ABANDONED_CART_TEMPLATE_ID=     # global fallback Brevo şablon ID'si (yoksa o tenant atlanır)
# ABANDONED_CART_MIN_AGE_HOURS=4        # sepet bu kadar saat hareketsizse hatırlatılır
# ABANDONED_CART_MAX_AGE_HOURS=48       # bundan eski sepetler "bayat", hatırlatılmaz
# STOREFRONT_BASE_URL=                  # tenant.domain yoksa "sepete dön" linki için temel URL

# ── PostHog (analytics — opsiyonel) ──
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.posthog.com

# ── OpenTelemetry (Observability) ──
# OTEL_SERVICE_NAME=medusa-ayna-genesis
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# DISABLE_OPENTELEMETRY=false

# ── İzleme & Yedekleme (üretim güvenlik ağı — bkz. docs/RUNBOOK-YEDEKLEME-IZLEME.md) ──
# HEARTBEAT_PING_URL=                 # healthchecks.io/cronitor ping URL'i (dead man's switch)
# BACKUP_DIR=/server/backups         # DB yedek dizini (KALICI volume olmalı!)
# BACKUP_RETENTION_DAYS=14           # bundan eski yerel yedekler silinir
# BACKUP_UPLOAD_CMD=                 # off-site yükleme (ZORUNLU); dosya $BACKUP_FILE env'inde
                                     #   örn: rclone copy "$BACKUP_FILE" b2:genesis-backups
# INTEGRITY_AUTOHEAL=false           # bütünlük kontrolünde güvenli oto-onarım (varsayılan kapalı)

# ── Admin IP Kısıtlama (güvenlik) ──
# Yönetim düzlemini (/admin/*) yalnızca tanımlı IP'lere açar. Mağaza etkilenmez.
# Mod: off (kapalı) | observe (sadece görülen IP'leri logla) | enforce (izinsizi 403'le)
# Güvenli geçiş: önce observe → GET /admin/security/events'ten görülen IP'yi öğren →
#   ADMIN_WHITELIST_IPS'e ekle → enforce. localhost (127.x, ::1) DAİMA izinli.
ADMIN_IP_RESTRICTION_MODE=off
# İzinli IP/CIDR listesi (virgülle). Örn: 88.99.100.101,10.0.0.0/24
ADMIN_WHITELIST_IPS=
