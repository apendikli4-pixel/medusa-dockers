# Medusa V2.15'in @medusajs/icons (React 19) ile @medusajs/medusa (React 18 peer)
# arasındaki bilinen peer-dependency çakışmasını otomatik geçer.
# Medusa community'nin önerdiği yaklaşım — kaldırıldığında "ERESOLVE" hatası alınır.
legacy-peer-deps=true

# CI/CD ortamlarında audit gürültüsünü engelle (manuel `npm audit` ile çalış)
audit=false
fund=false
